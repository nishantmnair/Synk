# Django Settings
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# Database Configuration
POSTGRES_DB=activity_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase Configuration (Backend Service Account)
# Download service account JSON from Firebase Console and save as serviceAccountKey.json
FIREBASE_CREDENTIALS_PATH=/app/serviceAccountKey.json
